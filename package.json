{
  "name": "ask-gaius",
  "module": "index.ts",
  "devDependencies": {
    "@types/alpinejs": "^3.13.11",
    "@types/bun": "^1.3.10",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0"
  },
  "dependencies": {
    "alpinejs": "^3.15.8",
    "dompurify": "^3.3.1",
    "marked": "^17.0.2",
    "stemmer": "^2.0.1",
    "turndown": "^7.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "scripts": {
    "build:linux": "bun build ./server.ts --compile --target=bun-linux-x64-modern --outfile output/askGaius-linux-x64",
    "build:windows": "bun build ./server.ts --compile --target=bun-windows-x64-modern --outfile output/askGaius-windows-x64",
    "build:windows:linux": "bun run build:linux && bun run build:windows"
  },
  "type": "module"
}
