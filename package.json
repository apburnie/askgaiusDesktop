{
  "name": "ask-gaius",
  "module": "index.ts",
  "devDependencies": {
    "@types/alpinejs": "^3.13.11",
    "@types/bun": "^1.3.10",
    "@types/express": "^5.0.6",
    "vite": "^7.3.1",
    "vite-plugin-singlefile": "^2.3.0"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.82",
    "alpinejs": "^3.15.8",
    "dompurify": "^3.3.1",
    "express": "^5.2.1",
    "marked": "^17.0.2",
    "stemmer": "^2.0.1",
    "turndown": "^7.2.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "scripts": {
    "build:browser": "rm -f output/odin/index-* && rm output/odin/index.html && bun build ./index.html --minify --target=browser --outdir output/odin",
    "dev": "bun run build:browser && MODE=dev bun run server.ts",
    "build:linux:x64": "bun build ./server.ts --compile --minify --bytecode --target=bun-linux-x64-modern --outfile output/exe/askGaius-linux-x64.exe",
    "build:linux:arm64": "bun build ./server.ts --compile --minify --bytecode --target=bun-linux-arm64 --outfile output/exe/askGaius-linux-arm64.exe",
    "build:linux": "bun run build:linux:x64 && bun run build:linux:arm64",
    "build:windows:x64": "bun build ./server.ts --compile --minify --bytecode --target=bun-windows-x64-modern --outfile output/exe/askGaius-windows-x64",
    "build:windows:arm64": "bun build ./server.ts --compile --minify --bytecode --target=bun-windows-arm64 --outfile output/exe/askGaius-windows-arm64",
    "build:windows": "bun run build:windows:x64 && bun run build:windows:arm64",
    "build:macos:x64": "bun build ./server.ts --compile --minify --bytecode --target=bun-darwin-x64 --outfile output/exe/askGaius-macos-x64.exe",
    "build:macos:arm64": "bun build ./server.ts --compile --minify --bytecode --target=bun-darwin-arm64 --outfile output/exe/askGaius-macos-arm64.exe",
    "build:macos": "bun run build:macos:x64 && bun run build:macos:arm64",
    "build": "bun run build:browser && bun run build:linux && bun run build:windows && bun run build:macos && bun run generate_readme.ts"
  },
  "type": "module"
}
